#include <iostream>
using namespace std;


class BankAccount{

public:

string name;
int AccountNo;
int Balance=0;
vector<int>transactions;
BankAccount(string username, int ID){


        this->name=username;
        this->AccountNo= ID;

}

void largest(){

    int max=0;
    for(int i=0; i<this->transactions.size(); i++){
        if(this->transactions[i]>max)
        max=this->transactions[i];
    }
    cout<<"Your largest transaction is: "<<max<<endl;


    cout<<"Press 0 for Exit or 1 for main menu: ";
    int x;
    cin>>x;    
    while(x!=0 && x!=1){
        cout<<"\nPlease choose a valid command\n"<<endl;cin>>x;
    }
    if(x==0)exit(1);
    else if(x==1)this->ui();
}
void withdraw(int INR){
    if(this->Balance>=INR){
        cout<<"Amount withdrawn successfully: "<<INR<<endl;
        this->Balance-=INR;
        this->transactions.push_back(0-INR);
    }
}
void withdraw(){
    int INR;
    cout<<"\nEnter the amount to be Withdrawn: ";
    cin>>INR;
    if(this->Balance>=INR){
        cout<<"\nAmount withdrawn successfully: "<<INR<<endl;
        this->Balance-=INR;
        this->transactions.push_back(0-INR);
    }
    else cout<<"\nInsufficient balance\n";
    cout<<"Current Available Balance: "<<this->Balance<<endl;
    cout<<"Press 0 for Exit or 1 for main menu: ";
    int x;
    cin>>x;    
    while(x!=0 && x!=1){
        cout<<"\nPlease choose a valid command\n"<<endl;cin>>x;
    }
    if(x==0)exit(1);
    else if(x==1)this->ui();
}
void deposit(int INR){
this->transactions.push_back(INR);
    this->Balance+=INR;
    cout<<"Amount "<<INR<<" has been added to your Account Balance\n";
}
void deposit(){
    int INR;
    cout<<"\nEnter the amount to be deposited: ";
    cin>>INR;
    this->transactions.push_back(INR);
    this->Balance+=INR;
    cout<<"\n---------------------------------------------------\nAmount "<<INR<<" has been added to your Account Balance\n";
     cout<<"Press 0 for Exit or 1 for main menu: ";
    int x;
    cin>>x;    
    while(x!=0 && x!=1){
        cout<<"\nPlease choose a valid command\n"<<endl;cin>>x;
    }
    if(x==0)exit(1);
    else if(x==1)this->ui();

}
void accountdetails(){

    cout<<"\n---------------------------------------------------\n Account Details\n---------------------------------------------------\nName: "<<this->name<<"\nAccount No: "<<this->AccountNo<<"\nCurrent Balance: "<<this->Balance<<"\n---------------------------------------------------\n";
    cout<<"Press 0 for Exit or 1 for main menu: ";
    int x;
    cin>>x;    
    while(x!=0 && x!=1){
        cout<<"\nPlease choose a valid command\n"<<endl;cin>>x;
    }
    if(x==0)exit(1);
    else if(x==1)this->ui();

}

void printTransaction(){

    cout<<"Your last 5 transactions are: " << endl;
    int count=0;

    for(int i=this->transactions.size()-1;i>=0;i--){
    if(count==5)break;
    count++;
    cout<<this->transactions[i]<<", ";
    }
    cout<<"\n---------------------------------------------------\nPress Y to know your largest transaction or Press any key to skip: ";
    char j;
    cin>>j;
    if(j=='Y' || j=='y')this->largest();
    else{
    cout<<"Press 0 for Exit or 1 for main menu: ";
    int x;
    cin>>x;    
    while(x!=0 && x!=1){
        cout<<"\nPlease choose a valid command\n"<<endl;cin>>x;
    }
    if(x==0)exit(1);
    else if(x==1)this->ui();
    }
}
void ui(){
    int x;
    cout<<"\n\nWhat do you wish to check"<<"\n 1. Transaction History \n 2. Account Details \n 3. Withdrawls \n 4. Deposit \n 5. Exit \n---------------------------------------------------"<<endl;
     cin>>x;    
    while(x<1 || x>5){
        cout<<"please choose a valid command"<<endl;cin>>x;
    }
    if(x==2) this->accountdetails();
    else if(x==3)this->withdraw();
    else if(x==1)this->printTransaction();
    else if(x==4)this->deposit();
    else if(x==5)exit(1);
    
    }

};

